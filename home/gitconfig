[user]
name = {{@@ user_name @@}}
email = {{@@ user_email @@}}

[core]
editor = {{@@ editor @@}}
autocrlf = input
whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol

[init]
defaultBranch = main

[push]
default = current
autoSetupRemote = true

[pull]
rebase = true

[diff]
colorMoved = default
algorithm = histogram
renames = true

[merge]
conflictStyle = diff3
tool = nvimdiff

[color]
ui = auto
