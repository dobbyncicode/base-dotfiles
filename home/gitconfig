[user]
    email = {{@@ user_email @@}}
    name = {{@@ user_name @@}}

[init]
    defaultBranch = main

[pull]
    rebase = true

[diff]
    algorithm = histogram
    renames = true

[color]
    ui = auto

[core]
    editor = {{@@ editor @@}}
    whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol

[alias]
    st = status
    co = checkout
    br = branch
    cm = commit -m
    ps = push
    pl = pull
    lg = log --graph --oneline --all --decorate
    unstage = reset HEAD --
    last = log -1 HEAD
